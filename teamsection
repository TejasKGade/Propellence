<!-- Team Member Detail Modal -->
<div id="team-detail-modal" class="modal">
  <div class="modal-content">
    <span class="close-modal">&times;</span>
    <div class="team-detail-container">
      <div class="team-header">
        <img class="team-detail-image" src="" alt="">
        <div class="team-info">
          <h1 class="team-detail-name"></h1>
          <h2 class="team-detail-position"></h2>
        </div>
      </div>
      
      <div class="team-bio-section">
        <h3>Biography</h3>
        <p class="team-detail-bio"></p>
      </div>
      
      <div class="team-contact-section">
        <h3>Contact Information</h3>
        <div class="contact-item">
          <span class="contact-label">Email:</span>
          <a href="#" class="team-detail-email"></a>
        </div>
        <div class="contact-item">
          <span class="contact-label">Phone:</span>
          <span class="team-detail-phone"></span>
        </div>
        <div class="contact-item">
          <span class="contact-label">Connect:</span>
          <div class="social-links">
            <a href="#" class="social-link linkedin" target="_blank">LinkedIn</a>
            <a href="#" class="social-link twitter" target="_blank">Twitter</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  /* Team Section Styles */
  .u-list-item.team-member {
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .u-list-item.team-member:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }
/* Modal Styles */
  .modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.7);
    overflow-y: auto;
  }
  
  .modal-content {
    background-color: #ffffff;
    margin: 2% auto;
    padding: 0;
    border: none;
    width: 90%;
    max-width: 900px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    box-sizing: border-box;
    overflow: hidden;
    animation: modalFadeIn 0.3s ease;
    font-family: 'Poppins', sans-serif !important;
  }
  
  @keyframes modalFadeIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .close-modal {
    color: var(--propellence-navy);
    float: right;
    font-size: 28px;
    font-weight: bold;
    cursor: pointer;
    padding: 15px 25px;
    line-height: 1;
    transition: color 0.2s ease;
  }
  
  .close-modal:hover {
    color: var(--propellence-green);
  }
  
  .team-detail-container {
    padding: 30px;
  }
  
  .team-header {
    display: flex;
    align-items: center;
    margin-bottom: 30px;
    border-bottom: 1px solid #eee;
    padding-bottom: 20px;
  }
  
  .team-detail-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    margin-right: 30px;
    border: 5px solid var(--propellence-cloud);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }
  
  .team-info {
    flex: 1;
  }
  
  .team-detail-name {
    color: var(--propellence-navy);
    font-size: 2.2rem;
    margin: 0 0 10px 0;
    font-weight: 600;
  }
  
  .team-detail-position {
    color: var(--propellence-blue);
    font-size: 1.5rem;
    margin: 0;
    font-weight: 500;
  }
  
  .team-bio-section {
    margin-bottom: 30px;
  }
  
  .team-bio-section h3 {
    color: var(--propellence-navy);
    font-size: 1.3rem;
    margin-bottom: 10px;
    font-weight: 600;
  }
  
  .team-detail-bio {
    color: var(--propellence-slate);
    font-size: 1rem;
    line-height: 1.6;
  }
  
  .team-contact-section {
    border-top: 1px solid #eee;
    padding-top: 20px;
  }
  
  .team-contact-section h3 {
    color: var(--propellence-navy);
    font-size: 1.3rem;
    margin-bottom: 15px;
    font-weight: 600;
  }
  
  .contact-item {
    margin-bottom: 12px;
    display: flex;
    align-items: center;
  }
  
  .contact-label {
    font-weight: 600;
    color: var(--propellence-slate);
    min-width: 80px;
  }
  
  .team-detail-email {
    color: var(--propellence-blue);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .team-detail-email:hover {
    color: var(--propellence-green);
    text-decoration: underline;
  }
  
  .team-detail-phone {
    color: var(--propellence-slate);
  }
  
  .social-links {
    display: flex;
    gap: 15px;
  }
  
  .social-link {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 25px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  
  .social-link.linkedin {
    background-color: #0077B5;
    color: white;
  }
  
  .social-link.linkedin:hover {
    background-color: #005885;
  }
  
  .social-link.twitter {
    background-color: #1DA1F2;
    color: white;
  }
  
  .social-link.twitter:hover {
    background-color: #0d8bd9;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .team-header {
      flex-direction: column;
      text-align: center;
    }
    
    .team-detail-image {
      margin-right: 0;
      margin-bottom: 20px;
    }
    
    .modal-content {
      width: 95%;
      margin: 5% auto;
    }
    
    .team-detail-container {
      padding: 20px;
    }
    
    .social-links {
      justify-content: center;
    }
  }
</style>

<script>
  // Get the modal
  const modal = document.getElementById('team-detail-modal');
  const closeModal = document.getElementsByClassName('close-modal')[0];
  const teamMembers = document.querySelectorAll('.team-member');
  
  // Add click event to each team member
  teamMembers.forEach(member => {
    member.addEventListener('click', function() {
      const memberId = this.getAttribute('data-member-id');
      const memberName = this.getAttribute('data-name');
      const memberPosition = this.getAttribute('data-position');
      const memberBio = this.getAttribute('data-bio');
      const memberEmail = this.getAttribute('data-email');
      const memberPhone = this.getAttribute('data-phone');
      const memberLinkedin = this.getAttribute('data-linkedin');
      const memberTwitter = this.getAttribute('data-twitter');
      
      // Populate modal with member data
      document.querySelector('.team-detail-image').src = this.querySelector('.u-image').src;
      document.querySelector('.team-detail-name').textContent = memberName;
      document.querySelector('.team-detail-position').textContent = memberPosition;
      document.querySelector('.team-detail-bio').textContent = memberBio;
      document.querySelector('.team-detail-email').textContent = memberEmail;
      document.querySelector('.team-detail-email').href = 'mailto:' + memberEmail;
      document.querySelector('.team-detail-phone').textContent = memberPhone;
      document.querySelector('.linkedin').href = memberLinkedin;
      document.querySelector('.twitter').href = memberTwitter;
      
      // Show modal
      modal.style.display = 'block';
    });
  });
  
  // Close modal when clicking the close button
  closeModal.addEventListener('click', function() {
    modal.style.display = 'none';
  });
  
  // Close modal when clicking outside of it
  window.addEventListener('click', function(event) {
    if (event.target === modal) {
      modal.style.display = 'none';
    }
  });
  
  // Close modal with Escape key
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape' && modal.style.display === 'block') {
      modal.style.display = 'none';
    }
  });
</script>